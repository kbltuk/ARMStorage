<Window x:Class="ARM.Client.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты" 
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="📊 Отчеты" 
                   FontSize="22" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="От:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}" Width="120"/>

                <TextBlock Grid.Column="2" Text="До:" VerticalAlignment="Center" Margin="10,0"/>
                <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}" Width="120"/>

                <Button Grid.Column="4" 
                        Content="Обновить" 
                        Command="{Binding RefreshCommand}"
                        Background="#3498DB"
                        Foreground="White"
                        Padding="15,8"
                        Margin="15,0,0,0"
                        Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" Margin="15,8"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Вкладки отчетов -->
        <TabControl Grid.Row="2">
            <!-- Вкладка: Продажи -->
            <TabItem Header="📈 Продажи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Топ товаров по продажам" 
                               FontWeight="Bold" 
                               Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding SalesReport}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Total}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Товары -->
            <TabItem Header="📦 Остатки товаров">
                <Grid Margin="10">
                    <DataGrid ItemsSource="{Binding StockReport}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalValue}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Пользователи -->
            <TabItem Header="👥 Активность пользователей">
                <Grid Margin="10">
                    <DataGrid ItemsSource="{Binding UserActivityReport}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="150"/>
                            <DataGridTextColumn Header="Кол-во заказов" Binding="{Binding OrdersCount}" Width="100"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Кнопка экспорта -->
        <Border Grid.Row="3" Background="#ECF0F1" Padding="15" CornerRadius="5" Margin="0,15,0,0">
            <Grid>
                <TextBlock Text="Экспорт отчетов" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📄 Excel" 
                            Command="{Binding ExportExcelCommand}"
                            Background="#27AE60"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            Cursor="Hand"/>
                    <Button Content="📑 PDF" 
                            Command="{Binding ExportPdfCommand}"
                            Background="#E74C3C"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>