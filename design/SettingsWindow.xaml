<Window x:Class="ARM.Client.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки системы" 
        Height="500" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="⚙️ Настройки системы" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <Rectangle Grid.Row="1" Height="1" Fill="#ECF0F1" Margin="0,0,0,20" VerticalAlignment="Top"/>

        <!-- Содержимое -->
        <Border Grid.Row="1" Background="White" Margin="0,10,0,10">
            <TabControl>
                <!-- Вкладка: Общие -->
                <TabItem Header="🎨 Оформление">
                    <StackPanel Margin="15">
                        <TextBlock Text="Тема оформления" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Width="200"
                                  Height="30"
                                  Margin="0,0,0,20"/>

                        <Separator Margin="0,10,0,10"/>

                        <CheckBox Content="Запускать при старте Windows" 
                                  IsChecked="{Binding RunOnStartup}"
                                  Margin="0,10"/>

                        <CheckBox Content="Показывать уведомления" 
                                  IsChecked="{Binding ShowNotifications}"
                                  Margin="0,5"/>
                    </StackPanel>
                </TabItem>

                <!-- Вкладка: База данных -->
                <TabItem Header="💾 База данных">
                    <StackPanel Margin="15">
                        <TextBlock Text="Строка подключения" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox Text="{Binding ConnectionString}" 
                                 Height="30"
                                 IsReadOnly="True"
                                 Background="#F0F0F0"
                                 Margin="0,0,0,10"/>

                        <Button Content="Проверить подключение" 
                                Command="{Binding TestConnectionCommand}"
                                Width="150"
                                Height="30"
                                Margin="0,10,0,0"/>

                        <TextBlock Text="{Binding ConnectionStatus}" 
                                   Foreground="{Binding ConnectionStatusColor}"
                                   Margin="0,10,0,0"/>

                        <Separator Margin="0,15,0,15"/>

                        <Button Content="Резервное копирование" 
                                Command="{Binding BackupCommand}"
                                Width="150"
                                Height="30"
                                Background="#3498DB"
                                Foreground="White"/>
                    </StackPanel>
                </TabItem>

                <!-- Вкладка: О программе -->
                <TabItem Header="ℹ️ О программе">
                    <StackPanel Margin="15" VerticalAlignment="Center">
                        <TextBlock Text="АРМ Система" 
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Версия 1.0.0" 
                                   HorizontalAlignment="Center"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Разработано для учебных целей" 
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#95A5A6"/>

                        <TextBlock Text="© 2024" 
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#95A5A6"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <!-- Кнопки -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" 
                    Content="Применить" 
                    Command="{Binding ApplyCommand}"
                    Background="#27AE60"
                    Foreground="White"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Cursor="Hand"/>

            <Button Grid.Column="2" 
                    Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    Background="#95A5A6"
                    Foreground="White"
                    Width="100"
                    Height="35"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
