<Window x:Class="ARM.Client.Views.OrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" 
        Height="600" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding Title}" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <Rectangle Grid.Row="1" Height="1" Fill="#ECF0F1" Margin="0,0,0,15"/>

        <!-- Информация о клиенте -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Клиент:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" Text="{Binding Order.CustomerName}" Margin="0,0,15,0"/>

                <TextBlock Grid.Column="2" Text="Телефон:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="3" Text="{Binding Order.CustomerPhone}"/>

                <TextBlock Grid.Row="1" Text="Комментарий:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" 
                         Text="{Binding Order.Comment}" 
                         Height="60" 
                         TextWrapping="Wrap"
                         Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- Таблица товаров -->
        <Border Grid.Row="3" Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Товары в заказе" FontWeight="Bold" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding OrderItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Height="200">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                        <DataGridTextColumn Header="Сумма" Binding="{Binding Total}" Width="100"/>
                        <DataGridTemplateColumn Header=" " Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" 
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="#E74C3C"
                                            Foreground="White"
                                            Width="25"
                                            Height="25"
                                            Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Добавление товара -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <ComboBox ItemsSource="{Binding AvailableProducts}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedProduct}"
                              Width="300"
                              Margin="0,0,10,0"
                              Height="30"/>

                    <TextBox Text="{Binding NewItemQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="80"
                             Margin="0,0,10,0"
                             Height="30"
                             TextAlignment="Center"/>

                    <Button Content="Добавить" 
                            Command="{Binding AddItemCommand}"
                            Background="#3498DB"
                            Foreground="White"
                            Height="30"
                            Padding="15,0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Итоговая сумма -->
        <Border Grid.Row="4" Background="#2C3E50" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="ИТОГО:" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="White"/>
                <TextBlock Text="{Binding Order.TotalAmount}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#F1C40F"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="Сохранить заказ" 
                    Command="{Binding SaveCommand}"
                    Background="#27AE60" 
                    Foreground="White"
                    Height="40"
                    Margin="0,0,10,0"
                    FontWeight="Bold"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" 
                    Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    Background="#95A5A6" 
                    Foreground="White"
                    Height="40"
                    Margin="10,0,0,0"
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>